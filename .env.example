# Frontend (Next.js) — committed value defaults
NEXT_PUBLIC_API_URL=https://your-vercel-deployment.vercel.app
NEXT_PUBLIC_PRODUCTION_URL=
NEXT_PUBLIC_ALCHEMY_API_KEY=

# Backend (Vercel) — runtime only
OPENAI_API_KEY=
ALCHEMY_API_KEY=

# Vercel KV — used for cache + replay protection
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
